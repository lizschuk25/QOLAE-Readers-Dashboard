        <div class="fg"><label>Type</label><select name="type"><option value="blocked">🚫 Block this day</option><option value="available">✅ Make available</option></select></div>
        <div class="fg"><label>Category</label><select name="category"><option value="">— Select —</option><option value="annualLeave">Annual Leave</option><option value="medical">Medical</option><option value="family">Family</option><option value="personal">Personal</option><option value="training">Training</option><option value="religious">Religious</option><option value="emergency">Emergency</option><option value="other">Other</option></select></div>
        <div class="fg"><label>Notes (optional)</label><input type="text" name="reason" placeholder="e.g. Doctor's appointment"></div>
        <button type="submit" class="bs">+ Add Override</button>
      </form>
      <% } %>

